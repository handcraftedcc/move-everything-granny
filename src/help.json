{
  "title": "Granny",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Granular sampler",
        "for Move Anything.",
        "",
        "Load a WAV file,",
        "then play notes.",
        "",
        "No sound until",
        "Sample File is set."
      ]
    },
    {
      "title": "Setup",
      "children": [
        {
          "title": "Sample File",
          "lines": [
            "Open Main page,",
            "then select",
            "Sample File.",
            "",
            "Choose a .wav",
            "from:",
            "/data/UserData/",
            "UserLibrary/",
            "Samples"
          ]
        },
        {
          "title": "WAV Format",
          "lines": [
            "Supported:",
            " PCM 8/16/24/32",
            " float32 WAV",
            "",
            "Audio is converted",
            "to mono internally."
          ]
        }
      ]
    },
    {
      "title": "Main",
      "lines": [
        "Sample File: pick",
        " .wav source file",
        "",
        "Position: base",
        " location in file",
        "Size: grain ms",
        "Density: grains/s",
        "Spray: pos spread",
        "Jitter: time rand",
        "Grain Gain: level"
      ]
    },
    {
      "title": "Scan",
      "lines": [
        "Scan Enable:",
        " on/off",
        "",
        "Scan: movement",
        " while note held",
        " (- back, + fwd)",
        "",
        "Scan End:",
        " wrap/pingpong/",
        " clamp/stop"
      ]
    },
    {
      "title": "Window / Tone",
      "lines": [
        "Window: grain env",
        " hann/triangle/",
        " blackman",
        "",
        "Hann: balanced",
        "Triangle: sharper",
        "Blackman: soft",
        " top end",
        "",
        "Win Shape:",
        " curve amount",
        "Quality:",
        " sets density +",
        " grain limits",
        "eco: 20 / 16",
        "normal: 40 / 32",
        "high: 60 / 48",
        "Trigger:",
        " per voice/global"
      ]
    },
    {
      "title": "Pitch / Voice",
      "lines": [
        "Pitch: semitones",
        "Fine: cents",
        "KeyTrack: note",
        " -> pitch amount",
        "",
        "Play Mode:",
        " mono/porta/poly",
        "Poly Voices:",
        " poly mode only",
        "Porta Time:",
        " porta mode ms",
        "Spread: stereo"
      ]
    },
    {
      "title": "ADSR Envelope",
      "lines": [
        "Attack: spawn",
        " gain rise time",
        "Decay: spawn",
        " gain fall time",
        "Sustain: held-note",
        " spawn level",
        "Release: spawn",
        " fade after note",
        "",
        "Each grain keeps",
        "its spawn gain."
      ]
    },
    {
      "title": "Disclaimer",
      "lines": [
        "Developed with",
        "AI assistance.",
        "",
        "Design + release",
        "decisions are",
        "human-reviewed."
      ]
    }
  ]
}
