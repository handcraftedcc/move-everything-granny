{
  "title": "Granny",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Granular sampler",
        "for Move Anything.",
        "",
        "Load a WAV file,",
        "then play notes.",
        "",
        "No sound until",
        "Sample File is set."
      ]
    },
    {
      "title": "Quick Start",
      "lines": [
        "1) Open Main page",
        "2) Select Sample",
        "   File",
        "3) Pick a .wav",
        "4) Play notes/pads",
        "",
        "Start folder:",
        "/data/UserData/",
        "UserLibrary/",
        "Samples"
      ]
    },
    {
      "title": "Menus",
      "children": [
        {
          "title": "Main",
          "lines": [
            "Sample File:",
            " choose source WAV",
            "",
            "Position: base file",
            " location",
            "",
            "Size: grain length",
            "Density: grains/sec",
            "Spray: pos spread",
            "Jitter: time random",
            "Grain Gain: level"
          ]
        },
        {
          "title": "Scan",
          "lines": [
            "Scan Enable:",
            " on/off",
            "",
            "Scan:",
            " speed + direction",
            " while held",
            "",
            "Scan End:",
            " wrap / pingpong",
            " clamp / stop"
          ]
        },
        {
          "title": "Window / Tone",
          "lines": [
            "Window:",
            " hann / triangle /",
            " blackman",
            "Hann: smooth",
            " default fade",
            "Triangle: sharp",
            " linear fade",
            "Blackman: most",
            " edge fade, soft",
            " highs",
            "",
            "Win Shape:",
            " envelope curve",
            "",
            "Grain Gain: level",
            "Quality: eco/",
            " normal/high",
            "Trigger: per voice",
            " or global cloud"
          ]
        },
        {
          "title": "Pitch / Voice",
          "lines": [
            "Pitch: semitones",
            "Fine: cents",
            "KeyTrack: note->",
            " pitch amount",
            "",
            "Play Mode:",
            " mono / porta /",
            " poly",
            "Poly Voices:",
            " used in poly mode",
            "Porta Time:",
            " used in porta",
            "Spread: stereo"
          ]
        }
      ]
    }
  ]
}
