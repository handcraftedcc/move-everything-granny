{
  "id": "granny-grain",
  "name": "Granny",
  "abbrev": "GRN",
  "version": "0.1.0",
  "description": "CPU-bounded granular instrument for Move Everything",
  "author": "move-anything contributors",
  "license": "MIT",
  "dsp": "dsp.so",
  "api_version": 2,
  "defaults": {
    "position": 0.5,
    "size_ms": 60,
    "density": 18,
    "spray": 0.15,
    "jitter": 0.1,
    "freeze": 0,
    "pitch_semi": 0,
    "fine_cents": 0,
    "keytrack": 1.0,
    "window_type": 0,
    "window_shape": 0.35,
    "grain_gain": 0.72,
    "polyphony": 4,
    "mono_legato": 0,
    "trigger_mode": 0,
    "spread": 0.2,
    "quality": 1,
    "sample_index": 0
  },
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "aftertouch": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Granny",
          "knobs": [
            "position",
            "size_ms",
            "density",
            "spray",
            "jitter",
            "pitch_semi",
            "keytrack",
            "spread"
          ],
          "params": [
            {
              "key": "position",
              "label": "Position",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.01
            },
            {
              "key": "size_ms",
              "label": "Size ms",
              "type": "float",
              "min": 5.0,
              "max": 250.0,
              "default": 60.0,
              "step": 5.0
            },
            {
              "key": "density",
              "label": "Density",
              "type": "float",
              "min": 1.0,
              "max": 60.0,
              "default": 18.0,
              "step": 2.0
            },
            {
              "key": "spray",
              "label": "Spray",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.15,
              "step": 0.01
            },
            {
              "key": "jitter",
              "label": "Jitter",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.1,
              "step": 0.01
            },
            {
              "key": "freeze",
              "label": "Freeze",
              "type": "int",
              "min": 0,
              "max": 1,
              "default": 0
            },
            {
              "key": "pitch_semi",
              "label": "Pitch Semi",
              "type": "float",
              "min": -24.0,
              "max": 24.0,
              "default": 0.0,
              "step": 1.0
            },
            {
              "key": "fine_cents",
              "label": "Fine Cents",
              "type": "float",
              "min": -100.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1.0
            },
            {
              "key": "keytrack",
              "label": "KeyTrack",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 1.0,
              "step": 0.01
            },
            {
              "key": "window_type",
              "label": "Window",
              "type": "int",
              "min": 0,
              "max": 2,
              "default": 0
            },
            {
              "key": "window_shape",
              "label": "Win Shape",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.35,
              "step": 0.01
            },
            {
              "key": "grain_gain",
              "label": "Grain Gain",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.72,
              "step": 0.01
            },
            {
              "key": "polyphony",
              "label": "Polyphony",
              "type": "int",
              "min": 1,
              "max": 8,
              "default": 4
            },
            {
              "key": "mono_legato",
              "label": "Mono Legato",
              "type": "int",
              "min": 0,
              "max": 1,
              "default": 0
            },
            {
              "key": "trigger_mode",
              "label": "Trigger",
              "type": "int",
              "min": 0,
              "max": 1,
              "default": 0
            },
            {
              "key": "spread",
              "label": "Spread",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.2,
              "step": 0.01
            },
            {
              "key": "quality",
              "label": "Quality",
              "type": "int",
              "min": 0,
              "max": 2,
              "default": 1
            },
            {
              "key": "sample_index",
              "label": "Sample",
              "type": "int",
              "min": 0,
              "max_param": "sample_count",
              "default": 0
            }
          ]
        }
      }
    }
  }
}
