{
  "id": "granny-grain",
  "name": "Granny",
  "abbrev": "GRN",
  "version": "0.1.0",
  "description": "CPU-bounded granular instrument for Move Everything",
  "author": "move-anything contributors",
  "license": "MIT",
  "dsp": "dsp.so",
  "api_version": 2,
  "defaults": {
    "position": 0.5,
    "scan": 0.0,
    "scan_enable": "on",
    "size_ms": 60,
    "density": 18,
    "spray": 0.15,
    "jitter": 0.1,
    "freeze": 0,
    "pitch_semi": 0,
    "fine_cents": 0,
    "keytrack": 1.0,
    "window_type": "hann",
    "window_shape": 0.35,
    "grain_gain": 0.72,
    "polyphony": 4,
    "play_mode": "mono",
    "portamento_ms": 120.0,
    "trigger_mode": "per_voice",
    "scan_end_mode": "wrap",
    "spread": 0.2,
    "quality": "normal",
    "sample_path": ""
  },
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "aftertouch": false,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "Granny",
          "knobs": [
            "position",
            "size_ms",
            "density",
            "spray",
            "jitter",
            "scan",
            "freeze",
            "quality"
          ],
          "params": [
            { "label": "Main", "level": "main" },
            { "label": "Scan", "level": "scan_menu" },
            { "label": "Window / Tone", "level": "window_tone" },
            { "label": "Pitch / Voice", "level": "pitch_voice" }
          ]
        },
        "main": {
          "name": "Main",
          "knobs": [
            "position",
            "size_ms",
            "density",
            "spray",
            "jitter",
            "freeze"
          ],
          "params": [
            "sample_path",
            "position",
            "size_ms",
            "density",
            "spray",
            "jitter",
            "freeze"
          ]
        },
        "pitch_voice": {
          "name": "Pitch / Voice",
          "knobs": [
            "pitch_semi",
            "fine_cents",
            "keytrack",
            "play_mode",
            "polyphony",
            "portamento_ms",
            "spread"
          ],
          "params": [
            "pitch_semi",
            "fine_cents",
            "keytrack",
            "play_mode",
            "polyphony",
            "portamento_ms",
            "spread"
          ]
        },
        "window_tone": {
          "name": "Window / Tone",
          "knobs": [
            "window_type",
            "window_shape",
            "grain_gain",
            "quality",
            "trigger_mode"
          ],
          "params": [
            "window_type",
            "window_shape",
            "grain_gain",
            "quality",
            "trigger_mode"
          ]
        },
        "scan_menu": {
          "name": "Scan",
          "knobs": [
            "scan_enable",
            "scan",
            "scan_end_mode"
          ],
          "params": [
            "scan_enable",
            "scan",
            "scan_end_mode"
          ]
        }
      }
    },
    "chain_params": [
      { "key": "sample_path", "name": "Sample File", "type": "filepath", "root": "/data/UserData/UserLibrary/Samples", "filter": ".wav", "default": "" },
      { "key": "position", "name": "Position", "type": "float", "min": 0.0, "max": 1.0, "step": 0.01, "default": 0.5 },
      { "key": "size_ms", "name": "Size", "type": "float", "min": 5.0, "max": 500.0, "step": 0.5, "default": 60.0 },
      { "key": "density", "name": "Density", "type": "float", "min": 1.0, "max": 60.0, "step": 0.5, "default": 18.0 },
      { "key": "spray", "name": "Spray", "type": "float", "min": 0.0, "max": 1.0, "step": 0.001, "default": 0.15 },
      { "key": "jitter", "name": "Jitter", "type": "float", "min": 0.0, "max": 1.0, "step": 0.001, "default": 0.1 },
      { "key": "scan", "name": "Scan", "type": "float", "min": -10.0, "max": 10.0, "step": 0.01, "default": 0.0 },
      { "key": "freeze", "name": "Freeze", "type": "enum", "options": ["off", "on"], "default": "off" },
      { "key": "pitch_semi", "name": "Pitch", "type": "int", "min": -24, "max": 24, "step": 1, "default": 0 },
      { "key": "fine_cents", "name": "Fine", "type": "float", "min": -100.0, "max": 100.0, "step": 1.0, "default": 0.0 },
      { "key": "keytrack", "name": "KeyTrack", "type": "float", "min": 0.0, "max": 1.0, "step": 0.01, "default": 1.0 },
      { "key": "window_type", "name": "Window", "type": "enum", "options": ["hann", "triangle", "blackman"], "default": "hann" },
      { "key": "window_shape", "name": "Win Shape", "type": "float", "min": 0.0, "max": 1.0, "step": 0.01, "default": 0.35 },
      { "key": "grain_gain", "name": "Grain Gain", "type": "float", "min": 0.0, "max": 1.0, "step": 0.01, "default": 0.72 },
      { "key": "polyphony", "name": "Poly Voices", "type": "int", "min": 1, "max": 8, "step": 1, "default": 4 },
      { "key": "play_mode", "name": "Play Mode", "type": "enum", "options": ["mono", "portamento", "poly"], "default": "mono" },
      { "key": "portamento_ms", "name": "Porta Time", "type": "int", "min": 0, "max": 2000, "step": 1, "default": 120 },
      { "key": "trigger_mode", "name": "Trigger", "type": "enum", "options": ["per_voice", "global_cloud"], "default": "per_voice" },
      { "key": "scan_enable", "name": "Scan Enable", "type": "enum", "options": ["off", "on"], "default": "on" },
      { "key": "scan_end_mode", "name": "Scan End", "type": "enum", "options": ["wrap", "pingpong", "clamp", "stop"], "default": "wrap" },
      { "key": "spread", "name": "Spread", "type": "float", "min": 0.0, "max": 1.0, "step": 0.01, "default": 0.2 },
      { "key": "quality", "name": "Quality", "type": "enum", "options": ["eco", "normal", "high"], "default": "normal" }
    ]
  }
}
